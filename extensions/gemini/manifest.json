{
  "name": "bqx",
  "display_name": "bqx – Agent-Native Data Cloud CLI",
  "description": "Data Cloud CLI optimized for AI agents. Provides query execution, dataset/table/routine/model inspection, agent analytics, and conversational analytics across BigQuery, Looker, AlloyDB, Spanner, and Cloud SQL.",
  "version": "0.4.0",
  "homepage": "https://github.com/bigquery/bqx",
  "tools": [
    {
      "name": "bqx_jobs_query",
      "description": "Execute a SQL query against BigQuery and return results as JSON.",
      "parameters": {
        "query": {
          "type": "string",
          "description": "SQL query string",
          "required": true
        },
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "use_legacy_sql": {
          "type": "boolean",
          "description": "Use legacy SQL dialect",
          "default": false
        },
        "location": {
          "type": "string",
          "description": "BigQuery location",
          "default": "US"
        }
      },
      "command": "bqx jobs query --query {query} --project-id {project_id} --format json"
    },
    {
      "name": "bqx_datasets_list",
      "description": "List all datasets in a BigQuery project.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        }
      },
      "command": "bqx datasets list --project-id {project_id} --format json"
    },
    {
      "name": "bqx_datasets_get",
      "description": "Get metadata for a specific BigQuery dataset.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        }
      },
      "command": "bqx datasets get --project-id {project_id} --dataset-id {dataset_id} --format json"
    },
    {
      "name": "bqx_tables_list",
      "description": "List all tables in a BigQuery dataset.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        }
      },
      "command": "bqx tables list --project-id {project_id} --dataset-id {dataset_id} --format json"
    },
    {
      "name": "bqx_tables_get",
      "description": "Get metadata for a specific BigQuery table including schema.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        },
        "table_id": {
          "type": "string",
          "description": "Table ID",
          "required": true
        }
      },
      "command": "bqx tables get --project-id {project_id} --dataset-id {dataset_id} --table-id {table_id} --format json"
    },
    {
      "name": "bqx_routines_list",
      "description": "List all routines (UDFs, procedures) in a BigQuery dataset.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        }
      },
      "command": "bqx routines list --project-id {project_id} --dataset-id {dataset_id} --format json"
    },
    {
      "name": "bqx_models_list",
      "description": "List all ML models in a BigQuery dataset.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        }
      },
      "command": "bqx models list --project-id {project_id} --dataset-id {dataset_id} --format json"
    },
    {
      "name": "bqx_analytics_doctor",
      "description": "Run a health check on the BigQuery agent_events table.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        }
      },
      "command": "bqx analytics doctor --project-id {project_id} --dataset-id {dataset_id} --format json"
    },
    {
      "name": "bqx_analytics_evaluate",
      "description": "Evaluate agent sessions against a quality threshold (latency or error rate).",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        },
        "evaluator": {
          "type": "string",
          "description": "Evaluator type: latency or error-rate",
          "required": true
        },
        "threshold": {
          "type": "number",
          "description": "Pass/fail threshold (ms for latency, 0-1 for rates)",
          "required": true
        },
        "last": {
          "type": "string",
          "description": "Time window (e.g. 1h, 24h, 7d)",
          "required": true
        },
        "agent_id": {
          "type": "string",
          "description": "Filter by agent name"
        }
      },
      "command": "bqx analytics evaluate --project-id {project_id} --dataset-id {dataset_id} --evaluator {evaluator} --threshold {threshold} --last {last} --format json"
    },
    {
      "name": "bqx_analytics_get_trace",
      "description": "Retrieve the full event trace for a specific agent session.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        },
        "session_id": {
          "type": "string",
          "description": "Session ID to retrieve",
          "required": true
        }
      },
      "command": "bqx analytics get-trace --project-id {project_id} --dataset-id {dataset_id} --session-id {session_id} --format json"
    },
    {
      "name": "bqx_analytics_list_traces",
      "description": "List recent agent session traces with event counts.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        },
        "last": {
          "type": "string",
          "description": "Time window (e.g. 1h, 24h, 7d)",
          "required": true
        },
        "agent_id": {
          "type": "string",
          "description": "Filter by agent name"
        },
        "limit": {
          "type": "number",
          "description": "Maximum traces to return",
          "default": 20
        }
      },
      "command": "bqx analytics list-traces --project-id {project_id} --dataset-id {dataset_id} --last {last} --format json"
    },
    {
      "name": "bqx_analytics_insights",
      "description": "Generate a comprehensive agent insights report with sessions, errors, latency, and tool usage.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        },
        "last": {
          "type": "string",
          "description": "Time window (e.g. 1h, 24h, 7d)",
          "required": true
        },
        "agent_id": {
          "type": "string",
          "description": "Filter by agent name"
        }
      },
      "command": "bqx analytics insights --project-id {project_id} --dataset-id {dataset_id} --last {last} --format json"
    },
    {
      "name": "bqx_analytics_drift",
      "description": "Run drift detection against a golden question set and report coverage.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        },
        "golden_dataset": {
          "type": "string",
          "description": "Golden dataset table name (in same dataset)",
          "required": true
        },
        "last": {
          "type": "string",
          "description": "Time window (e.g. 1h, 24h, 7d)",
          "default": "7d"
        },
        "min_coverage": {
          "type": "number",
          "description": "Minimum coverage threshold (0.0-1.0)",
          "default": 0.8
        }
      },
      "command": "bqx analytics drift --project-id {project_id} --dataset-id {dataset_id} --golden-dataset {golden_dataset} --last {last} --format json"
    },
    {
      "name": "bqx_analytics_distribution",
      "description": "Analyze event type distribution patterns across agent sessions.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        },
        "last": {
          "type": "string",
          "description": "Time window (e.g. 1h, 24h, 7d)",
          "required": true
        },
        "agent_id": {
          "type": "string",
          "description": "Filter by agent name"
        }
      },
      "command": "bqx analytics distribution --project-id {project_id} --dataset-id {dataset_id} --last {last} --format json"
    },
    {
      "name": "bqx_analytics_hitl_metrics",
      "description": "Show human-in-the-loop interaction metrics for agent sessions.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "dataset_id": {
          "type": "string",
          "description": "Dataset ID",
          "required": true
        },
        "last": {
          "type": "string",
          "description": "Time window (e.g. 1h, 24h, 7d)",
          "required": true
        },
        "agent_id": {
          "type": "string",
          "description": "Filter by agent name"
        }
      },
      "command": "bqx analytics hitl-metrics --project-id {project_id} --dataset-id {dataset_id} --last {last} --format json"
    },
    {
      "name": "bqx_ca_ask",
      "description": "Ask a natural language question over BigQuery data using a data agent.",
      "parameters": {
        "project_id": {
          "type": "string",
          "description": "GCP project ID",
          "required": true
        },
        "question": {
          "type": "string",
          "description": "Natural language question",
          "required": true
        },
        "agent": {
          "type": "string",
          "description": "Data agent to use (e.g. agent-analytics)"
        }
      },
      "command": "bqx ca ask {question} --project-id {project_id} --agent {agent} --format json"
    },
    {
      "name": "bqx_ca_ask_profile",
      "description": "Ask a natural language question over a Data Cloud source (Looker, AlloyDB, Spanner, Cloud SQL) using a YAML profile.",
      "parameters": {
        "profile": {
          "type": "string",
          "description": "Path to a CA source profile YAML file",
          "required": true
        },
        "question": {
          "type": "string",
          "description": "Natural language question",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "Output format: json, text, or table",
          "default": "json"
        }
      },
      "command": "bqx ca ask {question} --profile {profile} --format {format}"
    }
  ]
}
